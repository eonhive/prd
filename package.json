{
  "name": "prd",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "consumer:smoke:npm": "node ./scripts/external-consumer-smoke.mjs",
    "docs:check": "node ./scripts/check-docs-consistency.mjs",
    "clean": "node ./scripts/clean.mjs",
    "changeset": "changeset",
    "codex:check": "node ./scripts/codex-run.mjs check",
    "codex:pack": "node ./scripts/codex-run.mjs pack",
    "codex:run:web": "node ./scripts/codex-run.mjs run-web",
    "dev:web": "pnpm --filter @eonhive/prd-web-viewer dev",
    "preexamples:pack": "pnpm --filter @eonhive/prd-cli build",
    "examples:pack": "node packages/prd-cli/dist/cli.js pack examples/document-basic --out examples/dist/document-basic.prd && node packages/prd-cli/dist/cli.js pack examples/document-segmented-basic --out examples/dist/document-segmented-basic.prd && node packages/prd-cli/dist/cli.js pack examples/resume-basic --out examples/dist/resume-basic.prd && node packages/prd-cli/dist/cli.js pack examples/comic-basic --out examples/dist/comic-basic.prd && node packages/prd-cli/dist/cli.js pack examples/storyboard-basic --out examples/dist/storyboard-basic.prd",
    "preexamples:validate": "pnpm --filter @eonhive/prd-cli build",
    "examples:validate": "node packages/prd-cli/dist/cli.js validate examples/document-basic && node packages/prd-cli/dist/cli.js validate examples/document-segmented-basic && node packages/prd-cli/dist/cli.js validate examples/resume-basic && node packages/prd-cli/dist/cli.js validate examples/comic-basic && node packages/prd-cli/dist/cli.js validate examples/storyboard-basic",
    "foundation:gate": "node ./scripts/foundation-gate.mjs",
    "preruntime:conformance": "pnpm --filter @eonhive/prd-viewer-core... build && pnpm --filter @eonhive/prd-validator... build",
    "runtime:conformance": "node ./scripts/runtime-conformance-check.mjs",
    "release:bootstrap": "node ./scripts/release-bootstrap.mjs",
    "release:check": "pnpm typecheck && pnpm test && pnpm build && pnpm examples:validate && node ./scripts/release-smoke.mjs",
    "release:preflight": "node ./scripts/release-publish-preflight.mjs",
    "release:publish": "changeset publish",
    "release:status": "changeset status --verbose",
    "release:version": "changeset version && pnpm install --lockfile-only",
    "preexamples:smoke:document-basic": "pnpm --filter @eonhive/prd-cli build",
    "examples:smoke:document-basic": "node ./scripts/examples-smoke-document-basic.mjs",
    "preexamples:smoke:resume-basic": "pnpm --filter @eonhive/prd-cli build",
    "examples:smoke:resume-basic": "node ./scripts/examples-smoke-resume-basic.mjs",
    "preexamples:smoke:comic-basic": "pnpm --filter @eonhive/prd-cli build",
    "examples:smoke:comic-basic": "node ./scripts/examples-smoke-comic-basic.mjs",
    "preexamples:smoke:storyboard-basic": "pnpm --filter @eonhive/prd-cli build",
    "examples:smoke:storyboard-basic": "node ./scripts/examples-smoke-storyboard-basic.mjs",
    "examples:smoke": "node ./scripts/examples-smoke-all.mjs",
    "preexamples:smoke": "pnpm --filter @eonhive/prd-cli build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^5.4.19",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  }
}
