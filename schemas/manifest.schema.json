{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prd.eonhive.dev/schemas/manifest.schema.json",
  "title": "PRD Manifest",
  "description": "Canonical manifest schema for the first executable PRD foundation. The manifest remains the canonical package control surface.",
  "type": "object",
  "required": [
    "prdVersion",
    "manifestVersion",
    "id",
    "profile",
    "title",
    "entry"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "prdVersion": {
      "type": "string",
      "minLength": 1
    },
    "manifestVersion": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string",
      "pattern": "^[a-z0-9-]+(?:\\.[a-z0-9-]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "entry": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        { "not": { "pattern": "^/" } },
        { "not": { "pattern": "\\\\" } },
        { "not": { "pattern": "(^|/)\\.\\.(?:/|$)" } },
        { "not": { "pattern": "^[a-zA-Z][a-zA-Z0-9+.-]*:" } },
        { "not": { "pattern": "/$" } }
      ]
    },
    "profileVersion": {
      "type": "string",
      "minLength": 1
    },
    "public": {
      "type": "object",
      "additionalProperties": true
    },
    "localization": {
      "$ref": "#/$defs/localization"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "assets": {
      "oneOf": [
        {
          "type": "array",
          "items": { "$ref": "#/$defs/assetDeclaration" }
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "attachments": {
      "type": "array",
      "items": { "$ref": "#/$defs/attachmentDeclaration" }
    },
    "extensions": {
      "oneOf": [
        {
          "type": "array",
          "items": { "$ref": "#/$defs/extensionDeclaration" }
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "protected": {
      "$ref": "#/$defs/protectedDeclaration"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "profile": {
            "enum": ["general-document", "responsive-document"]
          }
        },
        "required": ["profile"]
      },
      "then": {
        "properties": {
          "entry": {
            "pattern": "^content/.+\\.json$"
          }
        }
      }
    }
  ],
  "additionalProperties": true,
  "$defs": {
    "localization": {
      "type": "object",
      "required": ["defaultLocale"],
      "properties": {
        "defaultLocale": {
          "type": "string",
          "minLength": 1
        },
        "availableLocales": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "textDirection": {
          "type": "string",
          "enum": ["ltr", "rtl", "auto"]
        }
      },
      "additionalProperties": true
    },
    "capabilityLists": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "minViewer": {
          "type": "string",
          "minLength": 1
        },
        "capabilities": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            { "$ref": "#/$defs/capabilityLists" }
          ]
        }
      },
      "additionalProperties": true
    },
    "assetDeclaration": {
      "type": "object",
      "required": ["href"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "attachmentDeclaration": {
      "type": "object",
      "required": ["href"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "extensionDeclaration": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "protectedDeclaration": {
      "type": "object",
      "properties": {
        "present": {
          "type": "boolean"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  }
}
