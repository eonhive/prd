{
  "name": "@eonhive/prd-packager",
  "version": "0.1.1",
  "description": "Build .prd ZIP archives from PRD package directories.",
  "keywords": [
    "prd",
    "portable-responsive-document",
    "packager",
    "archive",
    "zip"
  ],
  "license": "MIT",
  "homepage": "https://github.com/eonhive/PRD#readme",
  "bugs": {
    "url": "https://github.com/eonhive/PRD/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eonhive/PRD.git",
    "directory": "packages/prd-packager"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b && rm -f dist/.tsbuildinfo",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@eonhive/prd-types": "^0.1.1",
    "@eonhive/prd-validator": "^0.1.1",
    "fflate": "^0.8.2"
  }
}
