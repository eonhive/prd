{
  "name": "@eonhive/prd-cli",
  "version": "0.1.1",
  "description": "Command-line tools for PRD: validate and pack Portable Responsive Documents.",
  "keywords": [
    "prd",
    "portable-responsive-document",
    "cli",
    "validator",
    "packager"
  ],
  "license": "MIT",
  "homepage": "https://github.com/eonhive/PRD#readme",
  "bugs": {
    "url": "https://github.com/eonhive/PRD/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eonhive/PRD.git",
    "directory": "packages/prd-cli"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "prd": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b && rm -f dist/.tsbuildinfo",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@eonhive/prd-packager": "^0.1.1",
    "@eonhive/prd-types": "^0.1.1",
    "@eonhive/prd-validator": "^0.1.1"
  }
}
